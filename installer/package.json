{
  "name": "oh-my-kanban",
  "version": "0.2.5",
  "description": "Interactive setup wizard for oh-my-kanban — multi-platform project management CLI for AI agents (Plane, Linear, and more)",
  "type": "module",
  "bin": {
    "oh-my-kanban": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "cfonts": "^3.3.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
