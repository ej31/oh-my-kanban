{
  "name": "@oh-my-kanban/setup",
  "version": "0.1.0",
  "description": "Interactive setup wizard for the unified oh-my-kanban CLI",
  "type": "module",
  "bin": {
    "oh-my-kanban-setup": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "start": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "oh-my-kanban",
    "setup",
    "installer",
    "plane",
    "linear",
    "npx"
  ],
  "license": "MIT",
  "author": "ej31 <ej31@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ej31/oh-my-kanban.git"
  },
  "homepage": "https://github.com/ej31/oh-my-kanban/tree/main/installer#readme",
  "bugs": {
    "url": "https://github.com/ej31/oh-my-kanban/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
